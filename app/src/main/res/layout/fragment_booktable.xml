<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/card_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="30dp">

        <TextView
            android:id="@+id/txtShopTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="30dp"
            android:text="@string/txt_shop_title"
            android:textColor="@color/colorMain"
            android:textSize="@dimen/dimen_txt_title_22sp"
            android:textStyle="bold"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/boxSelectClb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/txtShopTitle">

            <ImageView
                android:id="@+id/iconLocation"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/icons8location48"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <TextView
                android:id="@+id/tvClb"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:text="Chọn câu lạc bộ Bi-a"
                android:textColor="@color/black"
                android:textSize="@dimen/dimen_txt_title_22sp"
                android:textStyle="bold"
                app:layout_constraintLeft_toRightOf="@id/iconLocation"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/searchBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_search_box"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvClb">

                <androidx.appcompat.widget.SearchView
                    android:id="@+id/searchView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:iconifiedByDefault="false"
                    android:queryHint="Tìm câu lạc bộ theo tên, địa chỉ..."
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintWidth_percent="0.9"
                    app:queryBackground="@android:color/transparent" />

                <ImageButton
                    android:id="@+id/btnFindNearby"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginEnd="10dp"
                    android:background="@android:color/transparent"
                    android:scaleType="fitCenter"
                    android:src="@drawable/icons8center60"
                    app:layout_constraintBottom_toBottomOf="@+id/searchView"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/searchView"
                    app:tint="@color/primary_emerald" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/boxDistanceFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/searchBox">

                <TextView
                    android:id="@+id/tvDistanceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lọc theo khoảng cách:"
                    android:textColor="@color/black"
                    android:textSize="@dimen/dimen_txt_20sp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Spinner
                    android:id="@+id/spinnerDistanceLimit"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:background="@drawable/bg_input_rounded"
                    android:entries="@array/distance_options"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="8dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/tvDistanceLabel"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvClbBia"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="10dp"
                android:scrollbars="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/boxDistanceFilter" />

            <TextView
                android:id="@+id/tvRvClbBia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="center"
                android:textColor="@color/accent_orange"
                android:textSize="18sp"
                android:textStyle="italic"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/boxDistanceFilter" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/selectDateGame"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/boxSelectClb">

            <ImageView
                android:id="@+id/ivLogoDateGame"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/icons8calendar48"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtSelectDateTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/txt_title_select_game"
                android:textColor="@color/black"
                android:textSize="@dimen/dimen_txt_title_22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/ivLogoDateGame"
                app:layout_constraintStart_toEndOf="@+id/ivLogoDateGame"
                app:layout_constraintTop_toTopOf="@+id/ivLogoDateGame" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="0dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_rounded"
                android:gravity="center_vertical"
                android:hint="dd/mm/yyyy"
                android:paddingHorizontal="20dp"
                android:paddingVertical="12dp"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/dimen_txt_title_22sp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtSelectDateTitle" />

            <ImageButton
                android:id="@+id/ibLogoSelectDate"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginEnd="15dp"
                android:backgroundTint="@android:color/transparent"
                android:src="@drawable/icons8calendar24"
                app:layout_constraintBottom_toBottomOf="@+id/tvDate"
                app:layout_constraintEnd_toEndOf="@+id/tvDate"
                app:layout_constraintTop_toTopOf="@+id/tvDate"
                app:tint="@color/gray_text" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/boxSelectTime"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/selectDateGame">

            <ImageView
                android:id="@+id/ivSelectTime"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/icons8watch48"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtSelectTimeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Chọn khung giờ (còn trống):"
                android:textColor="@color/black"
                android:textSize="@dimen/dimen_txt_20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/ivSelectTime"
                app:layout_constraintStart_toEndOf="@+id/ivSelectTime"
                app:layout_constraintTop_toTopOf="@+id/ivSelectTime" />

            <HorizontalScrollView
                android:id="@+id/hsvTimeline"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="10dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/txtSelectTimeTitle">

                <org.o7planning.myapplication.Owner.TimelineChartView
                    android:id="@+id/timelineChartView"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:minWidth="1000dp"
                    android:paddingHorizontal="10dp"
                    android:paddingTop="10dp" />
            </HorizontalScrollView>

            <TextView
                android:id="@+id/textViewTimeStart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="0dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_rounded"
                android:drawableStart="@drawable/icons8watch30"
                android:drawableTint="@color/gray_text"
                android:gravity="center"
                android:hint="Start time"
                android:paddingHorizontal="10dp"
                android:paddingVertical="12dp"
                android:textColor="@color/black"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/dimen_txt_title_22sp"
                app:layout_constraintEnd_toStartOf="@+id/textViewTimeEnd"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/hsvTimeline" />

            <TextView
                android:id="@+id/textViewTimeEnd"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="0dp"
                android:background="@drawable/bg_input_rounded"
                android:drawableStart="@drawable/icons8watch30"
                android:drawableTint="@color/gray_text"
                android:gravity="center"
                android:hint="End time"
                android:paddingHorizontal="10dp"
                android:paddingVertical="12dp"
                android:textColor="@color/black"
                android:textColorHint="@color/placeholder_text"
                android:textSize="@dimen/dimen_txt_title_22sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="1"
                app:layout_constraintStart_toEndOf="@+id/textViewTimeStart"
                app:layout_constraintTop_toBottomOf="@+id/hsvTimeline" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/boxCountPeopel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/boxSelectTime">

            <ImageView
                android:id="@+id/imgIconPeople"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/icons8crowd48"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/txtNumberPeople"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="@string/txt_number_peopel_title"
                android:textColor="@color/black"
                android:textSize="@dimen/dimen_txt_20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/imgIconPeople"
                app:layout_constraintStart_toEndOf="@id/imgIconPeople"
                app:layout_constraintTop_toTopOf="@+id/imgIconPeople" />

            <Spinner
                android:id="@+id/spinnerPeopel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input_rounded"
                android:paddingVertical="12dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/txtNumberPeople" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/boxVoucher"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:padding="10dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/boxCountPeopel">

            <ImageView
                android:id="@+id/ivVoucher"
                android:layout_width="35dp"
                android:layout_height="35dp"
                android:src="@drawable/icons8voucher48"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvDiscountCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Mã giảm giá"
                android:textColor="@color/black"
                android:textSize="@dimen/dimen_txt_title_22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/ivVoucher"
                app:layout_constraintStart_toEndOf="@+id/ivVoucher"
                app:layout_constraintTop_toTopOf="@+id/ivVoucher" />

            <EditText
                android:id="@+id/edtDiscountCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginEnd="10dp"
                android:background="@drawable/bg_input_rounded"
                android:ellipsize="end"
                android:hint="Nhập mã nếu có"
                android:maxLines="1"
                android:padding="12dp"
                android:textColor="@color/black"
                android:textColorHint="@color/placeholder_text"
                app:layout_constraintEnd_toStartOf="@+id/btnDiscountCode"
                app:layout_constraintHorizontal_weight="0.7"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDiscountCode" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnDiscountCode"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_button_apply_voucher"
                android:maxLines="1"
                android:paddingVertical="12dp"
                android:text="Áp dụng"
                android:textColor="@color/accent_orange"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@+id/edtDiscountCode"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_weight="0.3"
                app:layout_constraintStart_toEndOf="@+id/edtDiscountCode"
                app:layout_constraintTop_toTopOf="@+id/edtDiscountCode" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnConfirmBooking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_btn_orange"
            android:paddingVertical="15dp"
            android:text="@string/btn_confirm_booking"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/boxVoucher" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>