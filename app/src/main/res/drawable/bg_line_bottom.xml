<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_focused="true">
        <layer-list>
            <item
                android:left="-2dp"
                android:right="-2dp"
                android:top="-2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <solid android:color="#2196F3" /> <size android:height="2dp" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item
                android:left="-2dp"
                android:right="-2dp"
                android:top="-2dp">
                <shape android:shape="rectangle">
                    <solid android:color="@android:color/transparent" />
                </shape>
            </item>
            <item android:gravity="bottom">
                <shape android:shape="rectangle">
                    <solid android:color="#BDBDBD" /> <size android:height="1dp" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>